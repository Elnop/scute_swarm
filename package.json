{
	"name": "wizcard",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check": "cosmos-export --expose-imports && tsc --noEmit && tsc --noEmit -p tsconfig.cosmos.json && eslint && prettier --check .",
		"check:fix": "eslint --fix && prettier --write .",
		"prepare": "husky",
		"sb": "supabase",
		"sb:start": "supabase start",
		"sb:stop": "supabase stop",
		"sb:restart": "supabase stop && supabase start",
		"sb:status": "supabase status",
		"sb:reset": "supabase db reset --local",
		"sb:migrate": "supabase migration up --local",
		"sb:studio": "xdg-open http://127.0.0.1:54323",
		"sb:mail": "xdg-open http://127.0.0.1:54324",
		"cosmos": "cosmos --expose-imports",
		"cosmos:export": "cosmos-export --expose-imports",
		"clean": "rm -rf node_modules .next cosmos-export cosmos.imports.ts"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,mjs,mts}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,css,md}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@supabase/ssr": "^0.9.0",
		"@supabase/supabase-js": "^2.99.1",
		"next": "^16.2.1",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"sql.js": "^1.14.1",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@types/sql.js": "^1.4.11",
		"babel-plugin-react-compiler": "1.0.0",
		"eslint": "^9",
		"eslint-config-next": "16.1.6",
		"eslint-config-prettier": "^10.1.8",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"prettier": "^3.8.1",
		"react-cosmos": "^7.2.0",
		"react-cosmos-next": "^7.2.0",
		"supabase": "^2.78.1",
		"typescript": "5.9.3"
	}
}
